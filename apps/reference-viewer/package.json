{
  "name": "night-glow-reference-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "catalog:stars": "node scripts/download-star-catalog.mjs",
    "precompute:weather": "tsx scripts/precompute-weather-kernels.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:appearance": "tsx scripts/verify-realistic-appearance.ts",
    "test:celestial": "tsx scripts/verify-celestial-light.ts",
    "test:seeing": "tsx scripts/verify-seeing-psf.ts",
    "test:calibration": "tsx scripts/verify-regional-calibration.ts",
    "test:physics": "tsx scripts/verify-physical-model.ts",
    "test:weather": "tsx scripts/verify-weather-presets.ts",
    "test:weather:regional": "node --expose-gc --import tsx scripts/verify-regional-weather-output.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.57.0",
    "@types/leaflet": "^1.9.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "tsx": "^4.20.6",
    "vite": "^6.0.5"
  }
}
